# Database
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# App
APP_BASE_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3000/api/auth/google/callback"

# Gmail / PubSub
GOOGLE_PUBSUB_TOPIC="projects/YOUR_PROJECT_ID/topics/YOUR_TOPIC_NAME"
GOOGLE_PUBSUB_SUBSCRIPTION="projects/YOUR_PROJECT_ID/subscriptions/YOUR_SUBSCRIPTION_NAME"

# Storage
ATTACHMENT_STORAGE_BUCKET="email-attachments"

# Filtering config
# Replace placeholders with real internal domains later.
INTERNAL_EMAIL_DOMAINS="example.com"

# Comma-separated configurable starter denylist.
AUTOMATED_ALERT_DENYLIST="no-reply@,noreply@,do-not-reply@,alerts@,notifications@"

# OpenAI
OPENAI_API_KEY="sk-..."

# Pipeline
# Set to "true" when ready to auto-classify every new inbound email.
AUTO_TRIAGE_NEW_EMAILS="false"

# Slack
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
SLACK_ESCALATION_CHANNEL_NAME="ops-escalations"
# Find signing secret at: api.slack.com/apps → your app → Basic Information → Signing Secret
SLACK_SIGNING_SECRET="your-slack-signing-secret"
# Bot token — required for chat.update (edit card) + chat.postMessage (thread reply).
# Create at: api.slack.com/apps → your app → OAuth & Permissions → Bot Token Scopes → add chat:write
# Then: Install App to Workspace → copy the Bot User OAuth Token (starts with xoxb-)
SLACK_BOT_TOKEN="xoxb-your-bot-token"

# Dashboard operator session secret — signs HttpOnly auth cookies for triage actors.
# Generate a real value with: openssl rand -hex 32
DASHBOARD_OPERATOR_SESSION_SECRET="change-me-use-openssl-rand-hex-32"

# Cron endpoint protection. Set in Vercel → Settings → Environment Variables.
# Pass as: Authorization: Bearer <value>
# Generate with: openssl rand -hex 32
CRON_SECRET="change-me-use-openssl-rand-hex-32"

# Future domain-wide delegation. Do not implement in V1.
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=""
GOOGLE_WORKSPACE_ADMIN_EMAIL=""
